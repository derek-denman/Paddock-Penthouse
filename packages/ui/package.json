    "semantic-ui-react": "^2.1.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
