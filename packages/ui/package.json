{
  "name": "@p2p/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -p tsconfig.json && vite build",
    "lint": "echo 'lint skipped for @p2p/ui'",
    "typecheck": "tsc --noEmit -p tsconfig.json",
