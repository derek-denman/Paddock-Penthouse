# Shared
NODE_ENV=development
APP_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:4000
AUTH_MODE=local
RACE_DATA_MODE=SIM
AI_PROVIDER=local
VITE_API_ORIGIN=http://localhost:4000
VITE_AUTH_MODE=local
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/paddock
REDIS_URL=redis://localhost:6379

# Local auth fallback
LOCAL_JWT_SECRET=replace-with-local-dev-secret
OWNER_EMAIL=owner@example.com

# Cognito (production/default auth path)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=
COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback
COGNITO_LOGOUT_URI=http://localhost:5173/

# Google IdP details configured in Cognito / Secrets Manager (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional AI provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_RATE_LIMIT_PER_MINUTE=20

# Feature flags
ENABLE_F1_LIVE=false
ENABLE_ADMIN_BOOTSTRAP=true
F1_API_BASE=https://api.openf1.org/v1
F1_SESSION_KEY=
